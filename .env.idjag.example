# Config for cloudshell_adk_idjag.py (direct ID-JAG variant, no adapter).
# Copy these keys into your git-ignored .env and fill real values.
# The deploy copies them into env_vars so the Agent Engine worker sees them too.

# Okta org base URL
OKTA_DOMAIN=https://YOUR-ORG.oktapreview.com

# STEP3 audience — {OKTA_DOMAIN}/oauth2/{RESOURCE_AUTHZ_SERVER}
IDJAG_AUDIENCE=https://YOUR-ORG.oktapreview.com/oauth2/RESOURCE_AUTHZ_SERVER_ID

# Resource app authz server id (used in the STEP4 token endpoint)
RESOURCE_AUTHZ_SERVER=RESOURCE_AUTHZ_SERVER_ID

# Resource indicator for the target app. INFORMATIONAL ONLY: Agentspace (not this
# agent) makes the /authorize and /token calls, so this value does NOT flow into
# them from here. Set it on /authorize via the authorizer's Authorization URI
# (?resource=...), and on /token via Custom-AS audience config. Kept for reference.
AT_RESOURCE_URI=https://smarttriage.com/aud

# Scope requested at STEP3
IDJAG_SCOPES=smarttriage:read

# Agent identity (iss/sub of the client_assertion) + its signing key
AT_AI_AGENT_ID=wlpXXXXXXXXXXXXXXXXXX
AT_AGENT_PRIVATE_KEY_ID=YOUR_KEY_ID
# Multiline PEM; python-dotenv supports quoted multiline values.
AT_AGENT_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----
...key lines...
-----END PRIVATE KEY-----"

# Smart Triage MCP endpoint (called directly with the resource token)
SMARTTRIAGE_MCP_URL=https://smarttriage-1.onrender.com/mcp
